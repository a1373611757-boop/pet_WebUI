<navigation-bar title="我的订单" back="{{false}}" color="#203b30" background="#eef7ef"></navigation-bar>

<scroll-view class="page orders-page" scroll-y type="list">
  <view class="orders-head">
    <view>
      <text class="head-title">预约记录</text>
      <text class="head-desc">本地演示订单会保存在当前微信开发者工具缓存中。</text>
    </view>
    <button class="clear-btn" wx:if="{{orders.length}}" bindtap="clearLocalOrders">清空</button>
  </view>

  <view class="empty card" wx:if="{{!orders.length}}">
    <view class="empty-icon">约</view>
    <text class="empty-title">还没有预约</text>
    <text class="empty-desc">提交一次预约后，可以在这里查看订单状态和详情。</text>
    <button class="primary-btn empty-btn" bindtap="goBooking">去预约</button>
  </view>

  <view class="order-list" wx:else>
    <view class="order-card card" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="order-top">
        <text class="service-name">{{item.serviceName}}</text>
        <text class="status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="order-main">
        <text class="pet-name">{{item.petName}} · {{item.petType}}</text>
        <text class="price">{{item.priceText}}</text>
      </view>
      <text class="line">{{item.date}} {{item.timeSlot}}</text>
      <text class="line">{{item.address}}</text>
      <text class="created">提交于 {{item.createdAtText}}</text>
    </view>
  </view>
</scroll-view>
